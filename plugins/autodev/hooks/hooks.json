{
  "description": "Autodev session hooks — detect pending workflows and cleanup orphan worktrees on startup",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/workflow-detect.mjs\""
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/worktree-cleanup.mjs\""
          }
        ]
      }
    ]
  }
}
